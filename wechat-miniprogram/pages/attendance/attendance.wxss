.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.picker-arrow {
  margin-left: 10rpx;
  font-size: 24rpx;
}

.content {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
}

.attendance-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.attendance-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-date {
  font-size: 28rpx;
  color: #333;
}

.item-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.status-present {
  color: #67C23A;
}

.status-absent {
  color: #F56C6C;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}