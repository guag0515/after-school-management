<view class="container">
  <view class="header">
    <text class="title">每日餐饮</text>
    <picker mode="date" bindchange="bindDateChange" value="{{date}}" start="2020-01-01" end="{{currentDate}}">
      <view class="picker">
        {{date}}
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>
  
  <view class="content">
    <view wx:if="{{mealList.length > 0}}" class="meal-list">
      <view wx:for="{{mealList}}" wx:key="id" class="meal-item">
        <view class="item-date">{{item.date}}</view>
        
        <view class="meal-content">
          <view class="meal-item">
            <text class="meal-label">早餐:</text>
            <text class="meal-desc">{{item.breakfast}}</text>
          </view>
          <view class="meal-item">
            <text class="meal-label">午餐:</text>
            <text class="meal-desc">{{item.lunch}}</text>
          </view>
          <view class="meal-item">
            <text class="meal-label">晚餐:</text>
            <text class="meal-desc">{{item.dinner}}</text>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="empty">
      <text>暂无餐饮记录</text>
    </view>
  </view>
</view>